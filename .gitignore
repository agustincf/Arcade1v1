# Dependencias (se vuelven a bajar con "npm install", no se guardan)
node_modules/

# Builds y archivos generados
# OJO: "/build/" con barra inicial = solo la carpeta build de la RAÍZ.
# Sin la barra ignoraba apps/web/app/build/ (la página del builder) y la
# dejó fuera de git — fue la causa del 404 de /build en producción.
dist/
/build/
.publish/
.next/
out/
*.tsbuildinfo

# Secretos y configuracion local (NUNCA subir esto)
.env
.env.local
.env.mainnet
*.local
# Backups locales de configuracion (ej. .env.local.bak-...) — nunca subir
*.bak
.env*.bak*

# Config local de herramientas (Claude Code / GSD), no es del proyecto
.claude/

# Logs y basura del sistema
*.log
.DS_Store

# Artefactos de contratos (Foundry/Hardhat)
cache/
artifacts/
broadcast/

# Librerias y artefactos de Foundry
packages/contracts/lib/
packages/contracts/out/

# Estado de ratings del arbitro (runtime)
apps/server/data/
