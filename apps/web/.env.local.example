# Copiar a ".env.local" y completar. (No se sube al repo.)

# ID gratuito de WalletConnect/Reown (https://cloud.reown.com).
# Necesario para conectar billeteras de celular por QR.
NEXT_PUBLIC_WC_PROJECT_ID=

# URL del backend arbitro (en desarrollo).
NEXT_PUBLIC_ARBITER_URL=http://localhost:4000

# Dominio publico del sitio (para SEO: sitemap, canonical, Open Graph).
# Poné tu dominio real cuando lo tengas.
NEXT_PUBLIC_SITE_URL=https://arcade1v1.app

# Direcciones en Base Sepolia (se completan tras desplegar el contrato).
NEXT_PUBLIC_ESCROW_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=

# RPC propio de Base (Alchemy, QuickNode, etc.). En producción evita depender
# del RPC público; usar el mismo proveedor/red que RPC_URL del árbitro.
NEXT_PUBLIC_RPC_URL=
