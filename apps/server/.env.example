# Copiar a ".env" (no se sube al repo).

# Puerto del servidor arbitro.
PORT=4000

# Clave privada del ARBITRO (firma los resultados). Se genera con:
#   cast wallet new
# OJO: es un secreto. En testnet no hay plata real, pero cuidala igual.
ARBITER_PRIVATE_KEY=0x...

# Datos del contrato escrow para que la firma sea valida (EIP-712).
# Base Sepolia chainId = 84532. Local anvil = 31337.
CHAIN_ID=84532
ESCROW_ADDRESS=0x0000000000000000000000000000000000000000

# Exigir que los jugadores/agentes FIRMEN sus envios (recomendado en produccion).
# En dev queda en false para permitir invitados de prueba.
REQUIRE_AUTH=false

# Dominio permitido para CORS (en produccion: https://tudominio.com). Vacio = abierto.
ALLOWED_ORIGIN=

# Monitor del ETH del árbitro (paga cancelaciones/reembolsos automáticos).
# En producción con ESCROW_ADDRESS activo se enciende por defecto. En desarrollo,
# usar GAS_MONITOR_ENABLED=true para probarlo. RPC_URL debe ser un RPC propio.
RPC_URL=
GAS_MONITOR_ENABLED=
# Al bajar de este saldo se registra una alerta; opcionalmente se manda al webhook.
GAS_ALERT_ETH=0.005
GAS_CHECK_INTERVAL_MS=300000
GAS_ALERT_COOLDOWN_MS=21600000
GAS_ALERT_WEBHOOK_URL=
