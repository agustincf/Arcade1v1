# Copiar este archivo a ".env" y completar (NUNCA subir el .env real al repo).
# Se usa para desplegar el contrato en Base Sepolia (testnet) en la Parte 2.

# URL de un nodo de Base Sepolia (ej: de Alchemy/Infura, o el publico).
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Clave privada de la wallet que despliega (de prueba, con ETH de testnet).
# OJO: es un secreto. En testnet no hay plata real, pero igual cuidala.
PRIVATE_KEY=0x...

# Direccion del USDC de prueba en Base Sepolia.
USDC_ADDRESS=0x...

# Direccion del backend "arbitro" que firma resultados.
ARBITER_ADDRESS=0x...

# Tu wallet que recibe la comision.
PLATFORM_WALLET=0x...

# Comision en basis points: 1000 = 10%.
FEE_BPS=1000
