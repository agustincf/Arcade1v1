# Plantilla para el despliegue a Base MAINNET (DINERO REAL).
# Copiar a ".env.mainnet" y completar. NUNCA subir el archivo real al repo.
#
# OJO: acá NO va ninguna clave privada. En mainnet se firma con una WALLET DE
# HARDWARE (Ledger/Trezor) o un keystore, que pasás a forge con --ledger /
# --account al desplegar. La seguridad de la plataforma depende de esto.

# RPC de Base mainnet (público o de un proveedor como Alchemy/Infura).
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# USDC REAL de Base (Circle). Verificado on-chain: "USD Coin", 6 decimales.
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Dirección del backend "árbitro" que firma los resultados. Su LLAVE debe estar
# resguardada (KMS/HSM o secret del hosting), nunca en texto plano en el repo.
ARBITER_ADDRESS=0x...

# Wallet que cobra la comisión de la plataforma.
PLATFORM_WALLET=0x...

# Comisión en basis points: 1500 = 15% (tope del contrato: 2000 = 20%).
FEE_BPS=1500

# Wallet SEGURA (hardware/multisig) que despliega y queda como DUEÑA del contrato.
# Debe ser la MISMA que firma el deploy (el --sender de forge --ledger).
OWNER_ADDRESS=0x...
