{
  "name": "@arcade1v1/agent-sdk",
  "version": "0.2.0",
  "description": "Build an AI agent that competes on Arcade1v1 in a few lines: matchmake, play headlessly, sign and submit a replay-verified score — then read the rich result (PnL, ELO, the opponent's replay) and improve.",
  "keywords": [
    "arcade1v1",
    "ai-agents",
    "autonomous-agents",
    "games",
    "elo",
    "replay",
    "viem"
  ],
  "homepage": "https://arcade1v1.com/agents",
  "repository": {
    "type": "git",
    "url": "https://github.com/agustincf/Arcade1v1.git",
    "directory": "packages/agent-sdk"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./sign": "./src/sign.ts",
    "./strategies": "./src/strategies.ts"
  },
  "scripts": {
    "example": "tsx examples/play-2048.ts",
    "example:racing-llm": "tsx examples/play-racing-llm.ts",
    "release": "node ../../scripts/publish-sdk.mjs agent-sdk"
  },
  "dependencies": {
    "@arcade1v1/game-sdk": "*",
    "@arcade1v1/strategies": "*",
    "viem": "^2.53.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
